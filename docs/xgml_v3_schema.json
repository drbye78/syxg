            "snapshot_interpolation": {"type": "string", "enum": ["linear", "exponential"], "default": "linear"}
          }
        }
      },
      "additionalProperties": false
    },
    "sequencing": {
      "type": "object",
      "properties": {
        "sequencer_core": {
          "type": "object",
          "properties": {
