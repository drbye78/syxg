              "duration": {"type": "number", "minimum": 0.0},
              "velocity": {"type": "array", "items": {"type": "integer"}},
              "gate_time": {"type": "number", "minimum": 0.0, "maximum": 1.0},
              "humanize": {"type": "number", "minimum": 0.0, "maximum": 1.0}
