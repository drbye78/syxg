            "pattern_sync": {"type": "string", "enum": ["bar", "beat", "immediate"], "default": "bar"},
            "tempo_following": {"type": "boolean", "default": true},
            "external_sync": {"type": "boolean", "default": true}
          }
        },
        "workstation_sync": {
          "type": "object",
          "properties": {
            "motif_arpeggiator": {"type": "boolean", "default": true},
            "external_clock": {"type": "boolean", "default": true},
            "midi_clock_out": {"type": "boolean", "default": true},
            "transport_control": {"type": "boolean", "default": true}
          }
        },
        "advanced": {
          "type": "object",
          "properties": {
            "probability": {"type": "boolean", "default": true},
            "conditional_triggers": {"type": "boolean", "default": true},
            "groove_quantization": {"type": "boolean", "default": true},
            "microtiming": {"type": "boolean", "default": true},
            "adaptive_velocity": {"type": "boolean", "default": true}
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["xg_dsl_version"],
  "additionalProperties": false,
  "definitions": {
