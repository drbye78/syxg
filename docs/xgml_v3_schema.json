{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syxg.org/xgml-v3.0.schema.json",
  "title": "XGML v3.0 Schema",
  "description": "Complete JSON Schema for XGML v3.0 synthesizer configuration language",
  "type": "object",
  "properties": {
    "xg_dsl_version": {
      "type": "string",
      "enum": ["3.0"],
      "description": "XGML schema version identifier"
    },
    "description": {
      "type": "string",
      "description": "Optional human-readable description"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Optional ISO 8601 timestamp"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": {"type": "string"},
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "version": {"type": "string"}
      },
      "additionalProperties": true
    },
    "template": {
      "type": "string",
      "enum": [
        "childrens_piano",
        "basic_piano",
        "electric_piano",
        "organ",
        "strings",
        "brass",
        "woodwinds",
        "percussion",
        "basic_rock_band",
        "jazz_combo",
        "classical_orchestra",
        "electronic_workstation",
        "film_score",
        "game_audio"
      ],
      "description": "Built-in configuration template"
    },
    "synthesizer_core": {
      "type": "object",
      "properties": {
        "audio": {
          "type": "object",
          "properties": {
            "sample_rate": {
              "type": "integer",
              "enum": [22050, 44100, 48000, 88200, 96000],
              "default": 44100
            },
            "buffer_size": {
              "type": "integer",
              "enum": [64, 128, 256, 512, 1024, 2048],
              "default": 512
            },
            "real_time": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": false
        },
        "performance": {
          "type": "object",
          "properties": {
            "max_polyphony": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000,
              "default": 128
            },
            "voice_stealing": {
              "type": "string",
              "enum": ["priority", "round_robin", "oldest"],
              "default": "priority"
            },
            "dynamic_polyphony": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": false
        },
        "memory": {
          "type": "object",
          "properties": {
            "buffer_pool_size": {
              "type": "integer",
              "enum": [64, 128, 256],
              "default": 128
            },
            "envelope_pool_size": {
              "type": "integer",
              "enum": [256, 512],
              "default": 512
            },
            "filter_pool_size": {
              "type": "integer",
              "enum": [128, 256],
              "default": 256
            },
            "lfo_pool_size": {
              "type": "integer",
              "enum": [64, 128],
              "default": 128
            }
          },
          "additionalProperties": false
        },
        "monitoring": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "metrics": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["cpu", "latency", "polyphony", "memory"]
              }
            },
            "thresholds": {
              "type": "object",
              "properties": {
                "max_cpu_percent": {"type": "number", "minimum": 0, "maximum": 100, "default": 80.0},
                "max_latency_ms": {"type": "number", "minimum": 0, "default": 5.0},
                "max_memory_mb": {"type": "number", "minimum": 0, "default": 512.0}
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "workstation_features": {
      "type": "object",
      "properties": {
        "motif_integration": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "arpeggiator_system": {
              "type": "object",
              "properties": {
                "global_settings": {
                  "type": "object",
                  "properties": {
                    "tempo": {"type": "number", "minimum": 30.0, "maximum": 300.0, "default": 120.0},
                    "swing": {"type": "number", "minimum": -1.0, "maximum": 1.0, "default": 0.0},
                    "gate_time": {"type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.9},
                    "velocity_rate": {"type": "integer", "minimum": 0, "maximum": 200, "default": 100}
                  }
                },
                "arpeggiators": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer", "minimum": 0, "maximum": 3},
                      "pattern": {"type": "string"},
                      "octave_range": {"type": "integer", "minimum": 1, "maximum": 4, "default": 2},
                      "assigned_channels": {
                        "type": "array",
                        "items": {"type": "integer", "minimum": 0, "maximum": 15}
                      },
                      "hold_enabled": {"type": "boolean", "default": false},
                      "velocity_control": {"type": "boolean", "default": true}
                    },
                    "required": ["id"]
                  }
                },
                "pattern_library": {
                  "type": "object",
                  "properties": {
                    "load_motif_patterns": {"type": "boolean", "default": true},
                    "custom_patterns": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {"type": "string"},
                          "pattern": {"type": "array", "items": {"type": "number"}},
                          "length": {"type": "integer"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "s90_awm_stereo": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "global_mixing": {
              "type": "object",
              "properties": {
                "stereo_width": {"type": "number", "minimum": 0.0, "maximum": 2.0, "default": 1.0},
                "compression_ratio": {"type": "number", "minimum": 1.0, "maximum": 10.0, "default": 1.0},
                "limiter_threshold": {"type": "number", "minimum": -20.0, "maximum": 0.0, "default": 0.0}
              }
            },
            "velocity_layers": {
              "type": "object",
              "patternProperties": {
                "^preset_\\d+_\\d+$": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "min_velocity": {"type": "integer", "minimum": 0, "maximum": 127},
                      "max_velocity": {"type": "integer", "minimum": 0, "maximum": 127},
                      "sample": {"type": "string"},
                      "tuning": {"type": "number", "minimum": -100.0, "maximum": 100.0, "default": 0.0},
                      "volume": {"type": "number", "minimum": -60.0, "maximum": 12.0, "default": 0.0}
                    },
                    "required": ["min_velocity", "max_velocity", "sample"]
                  }
                }
              }
            },
            "stereo_pairs": {
              "type": "object",
              "patternProperties": {
                ".*": {
                  "type": "object",
                  "properties": {
                    "left": {"type": "string"},
                    "right": {"type": "string"},
                    "width": {"type": "number", "minimum": 0.0, "maximum": 2.0, "default": 1.0}
                  },
                  "required": ["left", "right"]
                }
              }
            }
          }
        },
        "multi_timbral": {
          "type": "object",
          "properties": {
            "channels": {"type": "integer", "minimum": 1, "maximum": 16, "default": 16},
            "voice_reserve": {
              "type": "object",
              "patternProperties": {
                "^channel_\\d+$": {"type": "integer", "minimum": 0, "maximum": 256}
              }
            },
            "channel_isolation": {"type": "boolean", "default": true}
          }
        },
        "xg_effects": {
          "type": "object",
          "properties": {
            "system_effects": {
              "type": "object",
              "properties": {
                "reverb": {
                  "type": "object",
                  "properties": {
                    "type": {"type": "integer", "minimum": 0, "maximum": 12},
                    "time": {"type": "number", "minimum": 0.1, "maximum": 10.0},
                    "level": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                    "hf_damping": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                    "diffusion": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                    "pre_delay": {"type": "number", "minimum": 0.0, "maximum": 1.0}
                  }
                },
                "chorus": {
                  "type": "object",
                  "properties": {
                    "type": {"type": "integer", "minimum": 0, "maximum": 5},
                    "rate": {"type": "number", "minimum": 0.01, "maximum": 10.0},
                    "depth": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                    "feedback": {"type": "number", "minimum": -1.0, "maximum": 1.0},
                    "mix": {"type": "number", "minimum": 0.0, "maximum": 1.0}
                  }
                }
              }
            },
            "variation_effects": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "slot": {"type": "integer", "minimum": 0, "maximum": 2},
                  "type": {"type": "integer", "minimum": 0, "maximum": 61},
                  "name": {"type": "string"},
                  "parameters": {"type": "object", "additionalProperties": true},
                  "routing": {
                    "type": "object",
                    "properties": {
                      "input_channels": {"type": "string", "enum": ["mono", "stereo"]},
                      "output_channels": {"type": "string", "enum": ["mono", "stereo"]}
                    }
                  }
                }
              }
            },
            "insertion_effects": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "channel": {"type": "integer", "minimum": 0, "maximum": 15},
                  "name": {"type": "string"},
                  "slots": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {"type": "string", "enum": ["eq", "compressor", "distortion", "phaser", "delay"]},
                        "parameters": {"type": "object", "additionalProperties": true},
                        "enabled": {"type": "boolean", "default": true}
                      }
                    }
                  }
                }
              }
            },
            "master_processing": {
              "type": "object",
              "properties": {
                "equalizer": {
                  "type": "object",
                  "properties": {
                    "enabled": {"type": "boolean", "default": true},
                    "type": {"type": "string", "enum": ["parametric", "vintage", "modern"]},
                    "bands": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "frequency": {"type": "number", "minimum": 20, "maximum": 20000},
                          "gain": {"type": "number", "minimum": -24, "maximum": 24},
                          "q": {"type": "number", "minimum": 0.1, "maximum": 10.0},
                          "type": {"type": "string", "enum": ["low_shelf", "peaking", "high_shelf"]}
                        }
                      }
                    }
                  }
                },
                "stereo_enhancer": {
                  "type": "object",
                  "properties": {
                    "enabled": {"type": "boolean", "default": false},
                    "width": {"type": "number", "minimum": 0.0, "maximum": 2.0},
                    "center_balance": {"type": "number", "minimum": -1.0, "maximum": 1.0},
                    "high_frequency_boost": {"type": "number", "minimum": 0.0, "maximum": 1.0}
                  }
                },
                "limiter": {
                  "type": "object",
                  "properties": {
                    "enabled": {"type": "boolean", "default": false},
                    "threshold": {"type": "number", "minimum": -20.0, "maximum": 0.0},
                    "ratio": {"type": "number", "minimum": 1.0, "maximum": 20.0},
                    "attack": {"type": "number", "minimum": 0.01, "maximum": 100.0},
                    "release": {"type": "number", "minimum": 1.0, "maximum": 1000.0},
                    "makeup_gain": {"type": "number", "minimum": 0.0, "maximum": 20.0},
                    "soft_knee": {"type": "boolean", "default": true},
                    "auto_release": {"type": "boolean", "default": true}
                  }
                },
                "dither": {
                  "type": "object",
                  "properties": {
                    "enabled": {"type": "boolean", "default": false},
                    "bit_depth": {"type": "integer", "enum": [16, 24]},
                    "type": {"type": "string", "enum": ["triangular", "rectangular", "shaped"]},
                    "noise_shaping": {"type": "boolean", "default": true}
                  }
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "synthesis_engines": {
      "type": "object",
      "properties": {
        "registry": {
          "type": "object",
          "properties": {
            "default_engine": {
              "type": "string",
              "enum": ["sf2", "sfz", "physical", "spectral", "fm"],
              "default": "sf2"
            },
            "fallback_engine": {
              "type": "string",
              "enum": ["sf2", "sfz", "physical", "spectral", "fm"],
              "default": "sf2"
            },
            "engine_priorities": {
              "type": "object",
              "properties": {
                "sf2": {"type": "integer", "minimum": 0, "maximum": 100},
                "sfz": {"type": "integer", "minimum": 0, "maximum": 100},
                "physical": {"type": "integer", "minimum": 0, "maximum": 100},
                "fm": {"type": "integer", "minimum": 0, "maximum": 100},
                "spectral": {"type": "integer", "minimum": 0, "maximum": 100}
              }
            }
          }
        },
        "channel_engines": {
          "type": "object",
          "patternProperties": {
            "^channel_\\d+$": {
              "type": "string",
              "enum": ["sf2", "sfz", "physical", "spectral", "fm"]
            }
          }
        },
        "sf2_engine": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": true},
            "soundfont_path": {"type": "string"},
            "bank": {"type": "integer", "minimum": 0, "maximum": 127, "default": 0},
            "program": {"type": "integer", "minimum": 0, "maximum": 127, "default": 0},
            "velocity_curve": {"type": "string", "enum": ["linear", "concave", "convex"], "default": "concave"},
            "tuning": {"type": "number", "minimum": -100.0, "maximum": 100.0, "default": 0.0},
            "awm_stereo": {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": false},
                "stereo_width": {"type": "number", "minimum": 0.0, "maximum": 2.0, "default": 1.0},
                "compression_ratio": {"type": "number", "minimum": 1.0, "maximum": 10.0, "default": 1.0}
              }
            },
            "zone_overrides": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "preset": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
                  "instrument": {"type": "integer"},
                  "generators": {
                    "type": "object",
                    "patternProperties": {
                      "^\\d+$": {"type": "integer"}
                    }
                  },
                  "modulators": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "src": {"type": "integer"},
                        "dest": {"type": "integer"},
                        "amount": {"type": "integer"}
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "sfz_engine": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "instrument_path": {"type": "string"},
            "global_parameters": {
              "type": "object",
              "properties": {
                "volume": {"type": "number", "minimum": -144.0, "maximum": 6.0},
                "pan": {"type": "number", "minimum": -100.0, "maximum": 100.0},
                "tune": {"type": "integer", "minimum": -100, "maximum": 100}
              }
            },
            "region_overrides": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "lokey": {"type": "integer", "minimum": 0, "maximum": 127},
                  "hikey": {"type": "integer", "minimum": 0, "maximum": 127},
                  "lovel": {"type": "integer", "minimum": 0, "maximum": 127},
                  "hivel": {"type": "integer", "minimum": 0, "maximum": 127},
                  "sample": {"type": "string"},
                  "volume": {"type": "number", "minimum": -144.0, "maximum": 6.0},
                  "pan": {"type": "number", "minimum": -100.0, "maximum": 100.0},
                  "tune": {"type": "integer", "minimum": -100, "maximum": 100},
                  "cutoff": {"type": "number", "minimum": 0, "maximum": 20000},
                  "resonance": {"type": "number", "minimum": 0.0, "maximum": 40.0},
                  "ampeg_attack": {"type": "number", "minimum": 0.0},
                  "ampeg_decay": {"type": "number", "minimum": 0.0},
                  "ampeg_sustain": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                  "ampeg_release": {"type": "number", "minimum": 0.0},
                  "round_robin": {"type": "integer", "minimum": 1}
                }
              }
            },
            "modulation_assignments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "source": {"type": "string"},
                  "destination": {"type": "string"},
                  "amount": {"type": "number", "minimum": -100.0, "maximum": 100.0},
                  "curve": {"type": "string", "enum": ["linear", "concave", "convex", "switch"]}
                }
              }
            }
          }
        },
        "physical_engine": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "model_type": {"type": "string", "enum": ["string", "tube", "plate", "membrane"]},
            "string_parameters": {
              "type": "object",
              "properties": {
                "length": {"type": "number", "minimum": 0.1, "maximum": 10.0},
                "tension": {"type": "number", "minimum": 1.0, "maximum": 1000.0},
                "mass_per_length": {"type": "number", "minimum": 0.001, "maximum": 1.0},
                "stiffness": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "damping": {"type": "number", "minimum": 0.0001, "maximum": 0.1},
                "pluck_position": {"type": "number", "minimum": 0.0, "maximum": 1.0}
              }
            },
            "waveguide_parameters": {
              "type": "object",
              "properties": {
                "delay_length": {"type": "integer", "minimum": 1},
                "reflection_coefficients": {"type": "array", "items": {"type": "number"}},
                "loss_factor": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "dispersion_enabled": {"type": "boolean"}
              }
            },
            "modal_synthesis": {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": false},
                "num_modes": {"type": "integer", "minimum": 1, "maximum": 64},
                "frequency_range": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2},
                "decay_range": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2}
              }
            }
          }
        },
        "spectral_engine": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "mode": {"type": "string", "enum": ["morph", "filter", "freeze", "shift", "stretch"]},
            "fft_settings": {
              "type": "object",
              "properties": {
                "fft_size": {"type": "integer", "enum": [512, 1024, 2048, 4096, 8192]},
                "hop_size": {"type": "integer"},
                "window_type": {"type": "string", "enum": ["hann", "hamming", "blackman"]},
                "overlap_factor": {"type": "number", "minimum": 0.125, "maximum": 1.0}
              }
            },
            "morphing": {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": true},
                "source_a": {"type": "string"},
                "source_b": {"type": "string"},
                "morph_position": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "morph_mode": {"type": "string", "enum": ["linear", "exponential", "perceptual"]}
              }
            },
            "transient_processing": {
              "type": "object",
              "properties": {
                "enabled": {"type": "boolean", "default": false},
                "attack_gain": {"type": "number", "minimum": 0.0, "maximum": 2.0},
                "sustain_gain": {"type": "number", "minimum": 0.0, "maximum": 2.0},
                "onset_threshold": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "transient_decay": {"type": "number", "minimum": 0.01, "maximum": 1.0}
              }
            }
          }
        },
        "fm_x_engine": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "algorithm": {"type": "integer", "minimum": 0, "maximum": 87},
            "algorithm_name": {"type": "string"},
            "master_volume": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "pitch_bend_range": {"type": "integer", "minimum": 0, "maximum": 24},
            "operators": {
              "type": "object",
              "patternProperties": {
                "^op_\\d+$": {
                  "type": "object",
                  "properties": {
                    "enabled": {"type": "boolean", "default": true},
                    "frequency_ratio": {"type": "number", "minimum": 0.1, "maximum": 32.0},
                    "detune_cents": {"type": "integer", "minimum": -100, "maximum": 100},
                    "feedback_level": {"type": "integer", "minimum": 0, "maximum": 7},
                    "waveform": {"type": "string", "enum": ["sine", "triangle", "sawtooth", "square"]},
                    "envelope": {
                      "type": "object",
                      "properties": {
                        "levels": {"type": "array", "items": {"type": "number"}, "minItems": 8, "maxItems": 8},
                        "rates": {"type": "array", "items": {"type": "number"}, "minItems": 8, "maxItems": 8},
                        "loop_start": {"type": "integer", "minimum": -1, "maximum": 7},
                        "loop_end": {"type": "integer", "minimum": -1, "maximum": 7}
                      }
                    },
                    "scaling": {
                      "type": "object",
                      "properties": {
                        "key_depth": {"type": "integer", "minimum": 0, "maximum": 7},
                        "velocity_sensitivity": {"type": "integer", "minimum": 0, "maximum": 7},
                        "key_curve": {"type": "string", "enum": ["linear", "exp", "log"]}
                      }
                    }
                  }
                }
              }
            },
            "lfos": {
              "type": "object",
              "patternProperties": {
                "^lfo_\\d+$": {
                  "type": "object",
                  "properties": {
                    "enabled": {"type": "boolean", "default": true},
                    "waveform": {"type": "string", "enum": ["sine", "triangle", "sawtooth", "square", "random", "noise"]},
                    "frequency": {"type": "number", "minimum": 0.01, "maximum": 20.0},
                    "depth": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                    "phase": {"type": "number", "minimum": 0.0, "maximum": 360.0},
                    "assignable": {"type": "boolean", "default": true}
                  }
                }
              }
            },
            "ring_modulation": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {"type": "integer"},
                "minItems": 2,
                "maxItems": 2
              }
            },
            "modulation_matrix": {
              "type": "object",
              "properties": {
                "routes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "source": {"type": "string"},
                      "destination": {"type": "string"},
                      "amount": {"type": "number", "minimum": -1.0, "maximum": 1.0},
                      "bipolar": {"type": "boolean", "default": false},
                      "curve": {"type": "string", "enum": ["linear", "exponential", "logarithmic", "sine"]},
                      "smoothing": {"type": "number", "minimum": 0.0, "default": 0.01}
                    }
                  }
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "effects_processing": {
      "type": "object",
      "properties": {
